		<content type="html">&lt;h2 style=&quot;text-align: center&quot;&gt;
	Early Years Team Management Structure&lt;/h2&gt;
&lt;h2 style=&quot;text-align: center&quot;&gt;
	Autumn Term 2013&lt;/h2&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	 &lt;/p&gt;
&lt;h1 style=&quot;text-align: center&quot;&gt;
	&lt;u&gt;Proprietors&lt;/u&gt;&lt;/h1&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	(Mr and Mrs &lt;span class=&quot;scayt-misspell&quot; data-scayt_word=&quot;Townley&quot; data-scaytid=&quot;1&quot;&gt;Townley&lt;/span&gt;)&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	 &lt;/p&gt;
&lt;h1 style=&quot;text-align: center&quot;&gt;
	&lt;u&gt;Headmistress&lt;/u&gt;&lt;/h1&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	(Mrs Shelley Stevenson)&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	B.Ed &lt;span class=&quot;scayt-misspell&quot; data-scayt_word=&quot;Hons&quot; data-scaytid=&quot;3&quot;&gt;Hons&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	Lead &lt;span class=&quot;scayt-misspell&quot; data-scayt_word=&quot;CPLO&quot; data-scaytid=&quot;5&quot;&gt;CPLO&lt;/span&gt; and &lt;span class=&quot;scayt-misspell&quot; data-scayt_word=&quot;SENCO&quot; data-scaytid=&quot;7&quot;&gt;SENCO&lt;/span&gt; for the Early Years&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	Safeguarding Update Training - JULY 12&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&lt;span class=&quot;scayt-misspell&quot; data-scayt_word=&quot;Paediatric&quot; data-scaytid=&quot;9&quot;&gt;Paediatric&lt;/span&gt; First Aid (12 HRS) - OCT 10&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	 &lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	 &lt;u&gt;&lt;strong&gt;Nursery Teacher&lt;/strong&gt;&lt;/u&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&lt;u&gt;&lt;strong&gt;Head of Early Years/Lower School&lt;/strong&gt;&lt;/u&gt;&lt;/p&gt;
&lt;p&gt;
	                                                                                 (Mrs Kelly &lt;span class=&quot;scayt-misspell&quot; data-scayt_word=&quot;Callaby&quot; data-scaytid=&quot;13&quot;&gt;Callaby&lt;/span&gt;)&lt;/p&gt;
&lt;p&gt;
	                                                             BA(&lt;span class=&quot;scayt-misspell&quot; data-scayt_word=&quot;Hons&quot; data-scaytid=&quot;11&quot;&gt;Hons&lt;/span&gt;) Family and Childhood Studies - Level 6&lt;/p&gt;
&lt;p&gt;
	                                                             Level 2 Award in Food Safety in Catering - 2013&lt;/p&gt;
&lt;p&gt;
	                                                                            Early Years Degree - Level 5&lt;/p&gt;
