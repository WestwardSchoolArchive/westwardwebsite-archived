	<entry>
		<title>Entrance Exam Results 2015</title>
		<link rel="alternate" type="text/html" href="/index.php/parents/entrance-exam-results/325-entrance-exam-results-2015.html"/>
		<published>2015-03-04T07:53:44Z</published>
		<updated>2015-03-04T07:53:44Z</updated>
		<id>https://westwardschool.co.uk/index.php/parents/entrance-exam-results/325-entrance-exam-results-2015.html</id>
		<author>
			<name>Mrs Stevenson</name>
		<email>westwardschool@btconnect.com</email>
		</author>
		<summary type="html">&lt;p align=&quot;center&quot;&gt;
	&lt;strong&gt;&lt;u&gt;Year 6 Senior School Examination Results 2015&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;
&lt;p align=&quot;center&quot;&gt;
	&lt;strong&gt;&lt;u&gt;16 children in the cohort &amp;ndash; 8 girls and 8 boys&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;
	&lt;strong&gt;&lt;span data-scayt_word=&quot;Boxhill&quot; data-scaytid=&quot;1&quot;&gt;Boxhill&lt;/span&gt;&lt;/strong&gt; &amp;ndash; 1 place offered&lt;/p&gt;
&lt;p&gt;
	&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; (1 academic scholarship)&lt;/p&gt;
&lt;p&gt;
	&amp;nbsp;&lt;/p&gt;
&lt;p&gt;
	&lt;strong&gt;City of London Freemen&amp;rsquo;s&lt;/strong&gt; &amp;ndash; 1 place offered (13+)&lt;/p&gt;
&lt;p&gt;
	&amp;nbsp;&lt;/p&gt;
&lt;p&gt;
	&lt;strong&gt;Claremont &lt;/strong&gt;&amp;ndash; 2 places offered&lt;/p&gt;
&lt;p&gt;
	&amp;nbsp;&lt;/p&gt;
&lt;p&gt;
	&lt;strong&gt;Dubai College&lt;/strong&gt; &amp;ndash; 1 place offered&lt;/p&gt;
&lt;p&gt;
	&amp;nbsp;&lt;/p&gt;
&lt;p&gt;
