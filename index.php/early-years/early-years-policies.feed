	&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;&lt;strong&gt;NAMED EARLY YEARS DEPUTY&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;Mrs Diana Lawrence&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;BA (&lt;span data-scayt_word=&quot;Hons&quot; data-scaytid=&quot;10&quot;&gt;Hons&lt;/span&gt;) Early Years - Level 6&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;&lt;span data-scayt_word=&quot;Paediatric&quot; data-scaytid=&quot;11&quot;&gt;Paediatric&lt;/span&gt; First Aid (12 HRS)&amp;nbsp;- Oct 2016&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;Level 2 Award in Food Safety in Catering - 2012&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;Early Years Foundation Degree - Level 5&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;NVQ Early Years Care and Education - Level 3&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&amp;nbsp;&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&amp;nbsp;&lt;/p&gt;
&lt;table style=&quot;border-bottom: medium none; border-left: medium none; width: 100%; border-top: medium none; border-right: medium none&quot;&gt;
	&lt;tbody&gt;
		&lt;tr&gt;
			&lt;th colspan=&quot;4&quot;&gt;
				&lt;h1&gt;
					&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;CORE EARLY YEARS/OUT OF SCHOOL CARE PRACTITIONERS&lt;/span&gt;&lt;/span&gt;&lt;/h1&gt;
				&lt;p style=&quot;text-align: center&quot;&gt;
					&amp;nbsp;&lt;/p&gt;
			&lt;/th&gt;
		&lt;/tr&gt;
		&lt;tr&gt;
			&lt;td style=&quot;text-align: center; width: 25%&quot;&gt;
				&lt;p&gt;
					&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;Mrs Lynn Hannon&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
				&lt;p&gt;
					&amp;nbsp;&lt;/p&gt;
				&lt;p&gt;
					&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;Reception Classroom Assistant/ Out of School Care Supervisor&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
				&lt;p&gt;
					&amp;nbsp;&lt;/p&gt;
				&lt;p style=&quot;font-size: 12.1599998474121px; line-height: 18.2399997711182px; background-color: rgb(255, 255, 255);&quot;&gt;
					&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;NVQ Level 2 &amp;amp; 3&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
				&lt;p style=&quot;font-size: 12.1599998474121px; line-height: 18.2399997711182px; background-color: rgb(255, 255, 255);&quot;&gt;
					&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;Early Years Care and Education&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
				&lt;p style=&quot;font-size: 12.1599998474121px; line-height: 18.2399997711182px; background-color: rgb(255, 255, 255);&quot;&gt;
					&amp;nbsp;&lt;/p&gt;
				&lt;p style=&quot;font-size: 12.1599998474121px; line-height: 18.2399997711182px; background-color: rgb(255, 255, 255);&quot;&gt;
					&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;CACHE Level 5 Diploma in &lt;span data-scayt_word=&quot;Playwork&quot; data-scaytid=&quot;14&quot;&gt;Playwork&lt;/span&gt; (NVQ) (&lt;span data-scayt_word=&quot;QCF&quot; data-scaytid=&quot;15&quot;&gt;QCF&lt;/span&gt;)&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
				&lt;p style=&quot;font-size: 12.1599998474121px; line-height: 18.2399997711182px; background-color: rgb(255, 255, 255);&quot;&gt;
					&amp;nbsp;&lt;/p&gt;
				&lt;p style=&quot;font-size: 12.1599998474121px; line-height: 18.2399997711182px; background-color: rgb(255, 255, 255);&quot;&gt;
					&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;&lt;span data-scayt_word=&quot;Playwork&quot; data-scaytid=&quot;16&quot;&gt;Playwork&lt;/span&gt;&amp;nbsp;Level 2 and 3&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
				&lt;p style=&quot;font-size: 12.1599998474121px; line-height: 18.2399997711182px; background-color: rgb(255, 255, 255);&quot;&gt;
					&amp;nbsp;&lt;/p&gt;
				&lt;p&gt;
					&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;Level 2 Award in Food Safety in Catering - 2012&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
				&lt;p&gt;
					&amp;nbsp;&lt;/p&gt;
				&lt;p&gt;
					&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;&lt;span data-scayt_word=&quot;Paediatric&quot; data-scaytid=&quot;17&quot;&gt;Paediatric&lt;/span&gt; First Aid (12 Hours) - 2014&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
			&lt;/td&gt;
