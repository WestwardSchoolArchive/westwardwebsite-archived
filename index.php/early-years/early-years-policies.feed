		<summary type="html">&lt;h2 style=&quot;text-align: center&quot;&gt;
	EARLY YEARS TEAM MANAGEMENT STRUCTURE&lt;/h2&gt;
&lt;h2 style=&quot;text-align: center&quot;&gt;
	AUTUMN TERM 2016&lt;/h2&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&amp;nbsp;&lt;/p&gt;
&lt;h1 style=&quot;text-align: center&quot;&gt;
	&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;PROPRIETORS&lt;/span&gt;&lt;/span&gt;&lt;/h1&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;Mr and Mrs &lt;span data-scayt_word=&quot;Townley&quot; data-scaytid=&quot;1&quot;&gt;Townley&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&amp;nbsp;&lt;/p&gt;
&lt;h1 style=&quot;text-align: center&quot;&gt;
	&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;HEADMISTRESS&lt;/span&gt;&lt;/span&gt;&lt;/h1&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;Mrs Shelley Stevenson&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;B.Ed &lt;span data-scayt_word=&quot;Hons&quot; data-scaytid=&quot;2&quot;&gt;Hons&lt;/span&gt; - Level 6&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;&lt;span style=&quot;line-height: 1.5;&quot;&gt;Designated Safeguarding Lead (DSL) and &lt;/span&gt;&lt;span data-scayt_word=&quot;SENCO&quot; data-scaytid=&quot;3&quot;&gt;SENCO&lt;/span&gt;&lt;span style=&quot;line-height: 1.5;&quot;&gt; for the Early Years&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;Safeguarding Update Training - SEP 14&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;&lt;span data-scayt_word=&quot;Paediatric&quot; data-scaytid=&quot;4&quot;&gt;Paediatric&lt;/span&gt; First Aid (12 HRS) - OCT 16&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&amp;nbsp;&lt;/p&gt;
&lt;h1 style=&quot;font-size: 12.16px; text-align: center;&quot;&gt;
	&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;span style=&quot;font-family: &amp;quot;times new roman&amp;quot;, times, serif;&quot;&gt;RECEPTION TEACHER&lt;/span&gt;&lt;/span&gt;&lt;/h1&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;&lt;strong&gt;HEAD OF EARLY YEARS &amp;amp; LOWER SCHOOL&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;&lt;span style=&quot;line-height: 1.5;&quot;&gt;Mrs Kelly &lt;/span&gt;&lt;span data-scayt_word=&quot;Callaby&quot; data-scaytid=&quot;57&quot;&gt;Callaby&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;&lt;span style=&quot;line-height: 1.5;&quot;&gt;BA (&lt;/span&gt;&lt;span data-scayt_word=&quot;Hons&quot; data-scaytid=&quot;5&quot;&gt;Hons&lt;/span&gt;&lt;span style=&quot;line-height: 1.5;&quot;&gt;) Family and Childhood Studies - Level 6&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot;text-align: center&quot;&gt;
	&lt;span style=&quot;font-size:14px;&quot;&gt;&lt;span style=&quot;font-family:times new roman,times,serif;&quot;&gt;&lt;span style=&quot;line-height: 1.5;&quot;&gt;Early Years Degree - Level 5&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
