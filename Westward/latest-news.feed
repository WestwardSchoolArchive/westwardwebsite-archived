	&amp;nbsp;&lt;/p&gt;
&lt;p align=&quot;center&quot;&gt;
	&lt;strong&gt;&lt;u&gt;&lt;span class=&quot;scayt-misspell&quot; data-scayt_word=&quot;U11’s&quot; data-scaytid=&quot;1&quot;&gt;U11&amp;rsquo;s&lt;/span&gt; PLAY &lt;span class=&quot;scayt-misspell&quot; data-scayt_word=&quot;DANESFIELD&quot; data-scaytid=&quot;3&quot;&gt;DANESFIELD&lt;/span&gt;&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;
	Eight excited &lt;span class=&quot;scayt-misspell&quot; data-scayt_word=&quot;u11&quot; data-scaytid=&quot;5&quot;&gt;u11&lt;/span&gt; boys walked their way to the &lt;span class=&quot;scayt-misspell&quot; data-scayt_word=&quot;Elmgrove&quot; data-scaytid=&quot;7&quot;&gt;Elmgrove&lt;/span&gt; Recreation Ground to take on &lt;span class=&quot;scayt-misspell&quot; data-scayt_word=&quot;Danesfield&quot; data-scaytid=&quot;9&quot;&gt;Danesfield&lt;/span&gt; after a long break in competition.&lt;/p&gt;
